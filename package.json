{
  "name": "@carbonenginejs/runtime-trinity",
  "version": "0.1.1",
  "private": true,
  "description": "CarbonEngineJS Trinity graph classes and JSON contract.",
  "type": "module",
  "exports": {
    ".": "./src/index.js",
    "./controllers": "./src/controllers/index.js",
    "./curves": "./src/curves/index.js",
    "./eve": "./src/eve/index.js",
    "./particle": "./src/particle/index.js",
    "./postProcess": "./src/postProcess/index.js",
    "./renderJob": "./src/renderJob/index.js",
    "./shader": "./src/shader/index.js",
    "./trinityCore": "./src/trinityCore/index.js",
    "./ui": "./src/ui/index.js",
    "./utilities": "./src/utilities/index.js",
    "./generated": "./src/generated/index.js",
    "./generated/*.js": "./src/generated/*.js",
    "./generated/*": "./src/generated/*/index.js"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "node scripts/lint_source_style.js",
    "build:npm": "npm run lint && node scripts/build_npm.js && rollup -c",
    "generate": "node scripts/regenerate_generated.js",
    "test": "npm run build:npm && node --test test/*.test.js"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/parser": "^7.29.7",
    "@babel/plugin-proposal-decorators": "^7.29.7",
    "@rollup/plugin-babel": "^7.1.0",
    "rollup": "^4.62.2"
  },
  "dependencies": {
    "@carbonenginejs/core-math": "^0.1.3",
    "@carbonenginejs/core-types": "^0.4.6"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
